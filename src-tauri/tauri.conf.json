{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OASYS Invest",
  "version": "0.2.0",
  "identifier": "com.oasys.invest",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:8000",
    "beforeDevCommand": "echo 'backend serves the UI on :8000'",
    "beforeBuildCommand": "echo 'backend serves the UI on :8000'"
  },
  "app": {
    "windows": [
      {
        "title": "OASYS Invest",
        "url": "http://127.0.0.1:8000",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../backend"
    ]
  }
}
